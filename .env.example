# ─────────────────────────────────────────────────────────────
# FLEX — Variables d'environnement
# Copie ce fichier en `.env` puis remplis les valeurs Supabase.
# Récupère-les dans : Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────

# URL de ton projet Supabase (ex: https://abcdxyz.supabase.co)
VITE_SUPABASE_URL=

# Clé "anon / public" (PAS la service_role !)
VITE_SUPABASE_ANON_KEY=

# Optionnel : laisse "true" pour faire tourner l'app en MODE DÉMO
# (données factices, aucune connexion backend requise).
# Passe à "false" une fois Supabase configuré.
VITE_DEMO_MODE=true

# ── Monétisation locale (Moov / Flooz) ──────────────────────────
# Ton numéro de réception. NE PAS committer ta vraie valeur : garde-la
# uniquement dans ton .env local (affiché masqué dans l'UI).
VITE_PAYMENT_MOOV_NUMBER=XXXXXXXX

# ── Admin ───────────────────────────────────────────────────────
# Pseudo (en minuscules) autorisé à ouvrir /flesh-admin-dashboard.
# En MODE DÉMO, si laissé vide, l'accès admin est ouvert localement pour test.
# En prod, ajoute aussi ton user_id dans la table app_admins (voir growth.sql).
VITE_ADMIN_USERNAME=

# ── Appels audio/vidéo (WebRTC) : serveur TURN ──────────────────
# INDISPENSABLE pour des appels fiables en 4G / NAT strict. Sans TURN dédié,
# beaucoup d'appels échouent. Crée un TURN gratuit (Metered : 50 Go/mois) ou
# auto-héberge coturn, puis renseigne ces 3 valeurs (sinon repli best-effort).
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
