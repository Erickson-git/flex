{
  "name": "flex",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "FLEX — le réseau social du Flex. Public Flow + Hideouts privés.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke.mjs",
    "mobile:sync": "npm run build && npx cap sync",
    "android:add": "npx cap add android",
    "android:open": "npx cap open android",
    "ios:add": "npx cap add ios",
    "ios:open": "npx cap open ios",
    "mobile:icons": "npx @capacitor/assets generate --iconBackgroundColor '#050505' --splashBackgroundColor '#050505'"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@supabase/supabase-js": "^2.45.4",
    "clsx": "^2.1.1",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.4",
    "vite": "^5.4.5",
    "vite-plugin-pwa": "^0.20.5"
  }
}
